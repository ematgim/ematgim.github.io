{
  "projects": {
    "frontend": {
      "projectType": "application",
      "sourceRoot": "apps/frontend",
      "targets": {
        "dev": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cd apps/frontend && vite"
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cd apps/frontend && tsc && vite build"
          }
        },
        "preview": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cd apps/frontend && vite preview"
          }
        }
      },
      "tags": []
    },
    "api": {
      "projectType": "application",
      "sourceRoot": "apps/api/src",
      "targets": {
        "dev": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cd apps/api && npm run dev"
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "options": {
            "command": "cd apps/api && tsc"
          }
        }
      },
      "tags": []
    }
  }
}
